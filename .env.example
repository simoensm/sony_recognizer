# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored — secrets never enter the repository.

# --- PostgreSQL (matches docker/docker-compose.dev.yml) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sonyrec

# --- Redis (job queue) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO in dev; any S3-compatible service in prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=photos

# --- Auth ---
# Generate a real secret with:  openssl rand -base64 32
BETTER_AUTH_SECRET=dev-only-secret-change-me-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
