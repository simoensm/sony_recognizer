# Production configuration — copy to .env.production ON THE SERVER and fill in.
# NEVER commit .env.production. Every secret should be generated fresh.

# Your subdomains (DNS A records → this server)
APP_HOST=sony.abovebelgium.be
S3_HOST=sony-photos.abovebelgium.be

# Public URLs derived from the hosts above
APP_URL=https://sony.abovebelgium.be
S3_PUBLIC_ENDPOINT=https://sony-photos.abovebelgium.be

# Postgres — generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# MinIO credentials — generate both: openssl rand -hex 16
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=photos

# Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public IP of the server (cameras use it for FTP passive mode)
FTP_PASV_HOST=

# Only for the Cloudflare-tunnel routing option; leave empty when using Caddy
CLOUDFLARE_TUNNEL_TOKEN=
